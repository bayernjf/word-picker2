{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "types": ["chrome", "node"]
  },
  "include": [
    "./content/**/*.ts",
    "./lib/**/*.ts",
    "./options/**/*.ts",
    "./popup/**/*.ts",
    "./service/**/*.ts",
    "./scripts/**/*.ts",
    "./tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "assets"
  ]
}
